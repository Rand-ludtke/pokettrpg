{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "pokettrpg",
  "version": "1.4.8",
  "identifier": "com.pokettrpg.desktop",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build:tauri",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "PokeTTRPG",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: asset: tauri:; connect-src 'self' ws: wss: http: https: tauri:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    },
    "windows": {
      "wix": null,
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
